# ─── Flask ───────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=true
SECRET_KEY="generate-with: python -c \"import secrets; print(secrets.token_urlsafe(32))\""

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql://attendease_user:StrongPass@2024@localhost:5432/attendease
POSTGRES_DB=attendease
POSTGRES_USER=attendease_user
POSTGRES_PASSWORD=StrongPass@2024

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://:RedisPass@2024@localhost:6379/0
REDIS_PASSWORD=RedisPass@2024

# ─── JWT ─────────────────────────────────────────────────────
JWT_SECRET_KEY="CHANGE_ME"
JWT_REFRESH_SECRET="CHANGE_ME"
JWT_ACCESS_EXPIRES_MINUTES=15
JWT_REFRESH_EXPIRES_DAYS=7

# ─── File Upload ─────────────────────────────────────────────
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# ─── Face Recognition ────────────────────────────────────────
FACE_RECOGNITION_TOLERANCE=0.5       # Lower = stricter (0.4-0.6)
LIVENESS_BLINK_THRESHOLD=3           # Blinks required for liveness
FACE_SNAPSHOT_FOLDER=uploads/snapshots

# ─── CAMERA API ───────────────────────────────────────────────
CAMERA_API_URL=http://localhost:8000/api/camera
CAMERA_API_KEY="CHANGE_ME"

# ─── Email (for password reset) ──────────────────────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=AttendEase <noreply@attendease.com>

# ─── App Settings ────────────────────────────────────────────
APP_NAME=AttendEase
FRONTEND_URL=http://127.0.0.1:5000
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
