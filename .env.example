# ── Copy this to .env and fill in your values ─────────────────

# Database
POSTGRES_DB=attendease
POSTGRES_USER=attendease
POSTGRES_PASSWORD=change_this_strong_password

# Flask security (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=generate_a_random_64_char_string
JWT_SECRET_KEY=generate_a_different_random_64_char_string

# Environment
FLASK_ENV=production

# Allowed frontend origins (your domain or * for any)
CORS_ORIGINS=https://yourdomain.com

# Ports (optional, defaults shown)
BACKEND_PORT=5000
FRONTEND_PORT=80
